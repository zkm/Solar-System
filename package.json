{
  "name": "solar-system",
  "version": "2.0.0",
  "main": "index.js",
  "repository": "git@github.com:zkm/Solar-System.git",
  "author": "Zach Schneider <me@zachschneider.com>",
  "license": "MIT",
  "devDependencies": {
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.35",
    "prettier": "^3.8.0",
    "sass": "^1.97.2",
    "stylelint": "^16.10.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "stylelint-scss": "^6.14.0"
  },
  "resolutions": {
    "tar@^7.5.2": "7.5.4",
    "@isaacs/brace-expansion@^5.0.0": "5.0.1",
    "brace-expansion@^5.0.2": "5.0.5",
    "minimatch@^10.1.1": "10.2.1",
    "immutable@^5.0.2": "5.1.5",
    "flatted@^3.3.3": "3.4.2",
    "picomatch@^2.0.4": "2.3.2",
    "picomatch@^2.3.1": "2.3.2"
  },
  "scripts": {
    "build:sass": "sass sass/styles.scss css/styles.css",
    "build:dist": "yarn build:sass && rm -rf dist && mkdir -p dist && cp index.html dist/ && cp -r css js dist/ && touch dist/.nojekyll",
    "lint:scss": "stylelint sass/**/*.scss",
    "lint:scss:fix": "stylelint sass/**/*.scss --fix",
    "format": "prettier --write \"**/*.{scss,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{scss,js,json,md}\"",
    "start": "python3 -m http.server 3000",
    "test": "jest",
    "watch:sass": "sass --watch sass/styles.scss css/styles.css",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.scss": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{js,json,md}": "prettier --write"
  }
}
